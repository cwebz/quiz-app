{
  "name": "smarter-than-the-internet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:edge": "opennextjs-cloudflare build && wrangler dev",
    "build": "opennextjs-cloudflare build",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:local": "wrangler d1 migrations apply smarter-than-the-internet --local",
    "db:prod": "wrangler d1 migrations apply smarter-than-the-internet --remote",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed-questions.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.90.0"
  }
}
